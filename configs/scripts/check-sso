#!/usr/bin/env bash
# Check if AWS SSO session is valid
# Exits 0 if a valid (non-expired) SSO session exists, 1 otherwise.
now=$(TZ=UTC date +%Y%m%d%H%M%S)
for f in ~/.aws/sso/cache/*.json; do
  [ -f "$f" ] || continue
  grep -q "accessToken" "$f" 2>/dev/null || continue
  exp=$(grep -oE '"expiresAt"[^"]*"[^"]*"' "$f" 2>/dev/null | head -1 | grep -oE '[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}' | tr -d 'T:-')
  [ -n "$exp" ] && [ "$exp" \> "$now" ] && exit 0
done
exit 1
