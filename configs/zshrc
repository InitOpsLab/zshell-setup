# Enable Powerlevel10k instant prompt. Should stay close to the top of ~/.zshrc.
# Initialization code that may require console input (password prompts, [y/n]
# confirmations, etc.) must go above this block; everything else may go below.
typeset -g POWERLEVEL9K_INSTANT_PROMPT=quiet
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

# === Zinit Bootstrapping ===
if [[ ! -f ~/.zinit/bin/zinit.zsh ]]; then
  echo "Installing Zinit plugin manager..."
  mkdir -p ~/.zinit
  git clone https://github.com/zdharma-continuum/zinit ~/.zinit/bin
fi
source ~/.zinit/bin/zinit.zsh

# === Source Config Sections ===
[[ -f ~/.zsh/plugins.zsh ]] && source ~/.zsh/plugins.zsh
[[ -f ~/.zsh/aliases.zsh ]] && source ~/.zsh/aliases.zsh
[[ -f ~/.zsh/functions.zsh ]] && source ~/.zsh/functions.zsh
[[ -f ~/.zsh/keybindings.zsh ]] && source ~/.zsh/keybindings.zsh

# === Completion Cache / Setup ===
# Docker CLI completions
fpath=("$HOME/.docker/completions" $fpath)
autoload -Uz compinit
if [[ -n ~/.zcompdump(#qN.mh+24) ]]; then
  compinit
  zcompile ~/.zcompdump 2>/dev/null
else
  compinit -C
fi
autoload -Uz colors && colors

# === Zsh Behavior ===
setopt autocd correct nocaseglob prompt_subst

# === History Settings ===
HISTFILE=~/.zsh_history
HISTSIZE=50000
SAVEHIST=50000
setopt inc_append_history share_history
setopt hist_ignore_dups hist_ignore_space hist_reduce_blanks
setopt hist_verify

# === Secrets ===
[[ -f ~/.secrets ]] && source ~/.secrets

# Auto-fetch git repos in background (for p10k pull/push arrows)
zinit ice wait lucid; zinit snippet OMZP::git-auto-fetch
GIT_AUTO_FETCH_INTERVAL=60

# To customize prompt, run `p10k configure` or edit ~/.p10k.zsh.
[[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh

# daylog - re-register completion now that compinit has run
(( $+functions[_daylog] )) && compdef _daylog daylog

# === Claude Code: random iTerm2 tab color per session ===
claude() {
  printf "\033]6;1;bg;red;brightness;%d\007"   $((RANDOM % 200 + 30))
  printf "\033]6;1;bg;green;brightness;%d\007" $((RANDOM % 200 + 30))
  printf "\033]6;1;bg;blue;brightness;%d\007"  $((RANDOM % 200 + 30))
  command claude "$@"
}
